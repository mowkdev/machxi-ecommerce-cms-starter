{
  "name": "machxi-ecommerce-cms-starter",
  "private": false,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:dev": "turbo dev --filter=@machxi/backend",
    "storefront:dev": "turbo dev --filter=@machxi/storefront",
    "docker:dev": "node scripts/docker-dev.mjs",
    "docker:prod": "docker compose -f docker/prod/docker-compose.yml --env-file docker/prod/.env up -d",
    "docker:prod:local": "node scripts/docker-prod-local.mjs",
    "docker:prod:down": "docker compose -f docker/prod/docker-compose.yml --env-file docker/prod/.env down",
    "setup:mcp": "node scripts/setup-mcp.mjs"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5",
      "undici": "5.20.0"
    },
    "patchedDependencies": {
      "payload@3.84.1": "patches/payload@3.84.1.patch"
    }
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  }
}