# Production env file template. Copy to /opt/machxi/.env on the VPS and
# replace every placeholder. The launcher (`pnpm docker:prod:local`)
# generates docker/prod/.env automatically with localhost-friendly defaults.

# ─── Image tags ───────────────────────────────────────────────────────────
# Pinned to commit SHAs in CI; rollback by setting a previous SHA.
BACKEND_IMAGE=ghcr.io/mowkdev/machxi-backend
STOREFRONT_IMAGE=ghcr.io/mowkdev/machxi-storefront
IMAGE_TAG=latest

# ─── Domain routing ───────────────────────────────────────────────────────
DOMAIN_STOREFRONT=yourdomain.com
DOMAIN_API=api.yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ─── Postgres (one container, two databases) ──────────────────────────────
POSTGRES_USER=machxi
POSTGRES_PASSWORD=REPLACE_ME_STRONG_RANDOM
POSTGRES_MEDUSA_DB=medusa
POSTGRES_PAYLOAD_DB=payload
# Host port the prod postgres binds to. Defaults to 5433 so it doesn't clash
# with a dev postgres on 5432. Only used by the local launcher.
POSTGRES_HOST_PORT=5433

# ─── Medusa backend ───────────────────────────────────────────────────────
# CSV of allowed origins. Storefront origin first.
STORE_CORS=https://yourdomain.com,https://www.yourdomain.com
ADMIN_CORS=https://api.yourdomain.com
AUTH_CORS=https://yourdomain.com,https://api.yourdomain.com
JWT_SECRET=REPLACE_ME_LONG_RANDOM_STRING
COOKIE_SECRET=REPLACE_ME_LONG_RANDOM_STRING

# Backend → Payload integration (Payload runs inside the storefront container).
PAYLOAD_SERVER_URL=http://storefront:3000

# ─── Object Storage (Contabo / Cloudflare R2 / AWS S3 / MinIO) ────────────
# Same S3 API across all providers — only the endpoint URL changes.
#
# Contabo:        https://<region>.contabostorage.com   (e.g. eu2, usc1)
# Cloudflare R2:  https://<account-id>.r2.cloudflarestorage.com
# AWS S3:         https://s3.<region>.amazonaws.com
# MinIO (local):  set via docker-compose.local-minio.yml override
#
# S3_FILE_URL is the public URL that storefront <img> tags and Medusa admin
# preview links resolve to. Putting Cloudflare in front of your bucket (CNAME
# cdn.yourdomain.com with orange-cloud proxy) gives you free edge caching
# and keeps your URLs portable across providers.
S3_ENDPOINT=https://eu2.contabostorage.com
S3_REGION=default
S3_BUCKET_MEDUSA=medusa-uploads
S3_BUCKET_PAYLOAD=payload-uploads
S3_ACCESS_KEY_ID=REPLACE_ME_OBJECT_STORAGE_KEY
S3_SECRET_ACCESS_KEY=REPLACE_ME_OBJECT_STORAGE_SECRET
S3_FILE_URL=https://cdn.yourdomain.com/medusa-uploads

# ─── Storefront / Payload ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_DEFAULT_REGION=us
NEXT_PUBLIC_DEFAULT_COUNTRY_CODE=us
PAYLOAD_SECRET=REPLACE_ME_LONG_RANDOM_STRING
PAYLOAD_PREVIEW_SECRET=REPLACE_ME_LONG_RANDOM_STRING
PAYLOAD_MCP_API_KEY=

# REAL PROD: leave unset. Schema lives in committed migrations (run via
# `pnpm payload migrate` before deploy). LOCAL PROD TEST: set to "true" to
# let Payload auto-sync schema and skip the migrations step.
# PAYLOAD_PUSH=true
