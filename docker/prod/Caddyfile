# Caddy 2 reverse proxy for production. Auto-issues Let's Encrypt certs for
# the two hostnames on first request (state persisted in caddy-data volume).
#
# Caddy uses its internal CA (self-signed) for localhost / *.localhost
# automatically, and ACME (Let's Encrypt) for public hostnames — so no
# explicit tls directive is needed in either environment.
#
# Object Storage / CDN is NOT proxied through Caddy. The recommended setup is
# a Cloudflare CNAME `cdn.yourdomain.com` pointing at your bucket endpoint
# with the orange-cloud proxy enabled — Cloudflare caches at the edge and
# absorbs egress, so the VPS bandwidth is reserved for API + page traffic.

{
	# ADMIN_EMAIL receives Let's Encrypt expiry notices.
	email {$ADMIN_EMAIL:admin@example.com}
}

{$DOMAIN_API} {
	# Medusa product/media uploads can be larger than the default 10 MB.
	request_body {
		max_size 50MB
	}

	reverse_proxy backend:9000 {
		# Forward real client IPs to the backend for rate-limiting / logging.
		header_up X-Real-IP {remote_host}
	}
}

{$DOMAIN_STOREFRONT}, www.{$DOMAIN_STOREFRONT} {
	reverse_proxy storefront:3000
	encode gzip zstd

	# Cache static assets aggressively; Next.js fingerprints filenames.
	@static {
		path /_next/static/*
	}
	header @static Cache-Control "public, max-age=31536000, immutable"
}
