# Medusa backend URL. Server-only (no NEXT_PUBLIC_ prefix) so it isn't shipped
# to the browser. Used by middleware.ts and src/lib/medusa.ts.
# Remember to update CORS settings on the backend — see
# https://docs.medusajs.com/learn/configurations/medusa-config#httpstorecors
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key bound to a sales channel. Required for all /store/* calls.
# Create one in Medusa Admin → Settings → Publishable API Keys.
# https://docs.medusajs.com/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Canonical storefront URL. Used for SEO metadata (canonical URLs, JSON-LD,
# sitemap, og:url). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:8000

# Fallback region (ISO-2 lowercase) when middleware can't resolve a region from
# the URL or the x-vercel-ip-country header. Must match a configured region in
# Medusa Admin.
NEXT_PUBLIC_DEFAULT_REGION=us

# Optional — Medusa Cloud S3 host + path prefix for image optimization. When
# both are set, next.config.ts adds a matching remotePattern. Leave blank for
# local dev (Medusa serves uploads from localhost).
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
