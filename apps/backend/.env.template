STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
# Redis: leave UNSET in local dev — Medusa falls back to an in-memory event
# bus / cache / locking / workflow engine. The prod docker-compose stack sets
# REDIS_URL=redis://redis:6379 automatically. For local prod-parity testing
# use `pnpm docker:prod` instead of plain `pnpm dev`.
# REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=postgres://db-user:db-password@localhost:5432/medusa
DB_NAME=medusa

# Payload CMS integration
# The Payload API key and user collection are managed via Medusa Admin →
# Settings → Payload Integration (stored in payload_integration_settings).
# Only the server URL belongs in env because it changes with infra, not creds.
PAYLOAD_SERVER_URL=http://localhost:8000

# S3 file module — points at MinIO from docker-compose.yml.
# https://docs.medusajs.com/resources/infrastructure-modules/file/s3
# Unset S3_BUCKET to fall back to Medusa's default local file provider.
S3_FILE_URL=http://localhost:9100/medusa-uploads
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=medusa-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
