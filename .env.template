# Local development infrastructure (docker-compose.yml).
# Copy this file to `.env` and adjust if needed, then run `pnpm docker:dev`.

# Postgres
POSTGRES_USER=db-user
POSTGRES_PASSWORD=db-password
POSTGRES_HOST_PORT=5432
POSTGRES_MEDUSA_DB=medusa
POSTGRES_PAYLOAD_DB=payload

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_MEDUSA_BUCKET=medusa-uploads
MINIO_PAYLOAD_BUCKET=payload-uploads

# Claude Code MCP servers (referenced from .mcp.json)
# Create a GitHub Personal Access Token at https://github.com/settings/tokens
# Classic token needs: repo, read:org, read:user. Fine-grained: repo contents R/W,
# issues R/W, pull requests R/W on the repos you want Claude to access.
# Leave blank to disable the GitHub MCP server.
GITHUB_PERSONAL_ACCESS_TOKEN=
